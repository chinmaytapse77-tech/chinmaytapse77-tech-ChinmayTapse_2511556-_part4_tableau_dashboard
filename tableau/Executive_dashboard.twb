      <aliases enabled='yes' />
      <column caption=' Profit Margin' datatype='real' name='[Calculation_0367528889323520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0367528889524225]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0367528889585666]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0367528889700355]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNTD([order_id])' />
      </column>
      <column caption='Shipping delay bucket' datatype='string' name='[Calculation_0367528889786372]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN &quot;Fast (0-2 days)&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 4 THEN &quot;Standard (3-4 days)&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 6 THEN &quot;Slow (5-6 days)&quot;&#13;&#10;ELSE &quot;Very Slow (7+ days)&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit Per Order' datatype='real' name='[Calculation_0367528889876485]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / COUNTD([order_id])' />
      </column>
